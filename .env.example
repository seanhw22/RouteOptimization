# MDVRP Database Configuration Example
# =====================================
# Copy this file to .env and update with your actual database credentials

# PostgreSQL Database Connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mdvrp

# Use database for MDVRP runs (true/false)
# - true: Try database first, fallback to CSV files if database fails
# - false: Use CSV files directly (skip database)
USE_DATABASE=false

# Dataset ID to load from database
# Only used when USE_DATABASE=true
DATASET_ID=1

# Configuration Guide:
# ===================
#
# Update with your actual credentials:
# - user: Your PostgreSQL username
# - password: Your PostgreSQL password
# - host: localhost (or remote server)
# - port: 5432 (default PostgreSQL port)
# - database: mdvrp (or your database name)
#
# Data Source Priority (when USE_DATABASE=true):
# 1. Try database connection first
# 2. If database fails, fallback to CSV files in data/ directory
# 3. Error if both are unavailable
#
# Example for production:
# DATABASE_URL=postgresql://mdvrp_user:secure_password@db.example.com:5432/mdvrp_prod
# USE_DATABASE=true
# DATASET_ID=1
